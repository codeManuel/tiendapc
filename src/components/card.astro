---
const { id, title, price, specs, img, link } = Astro.props;

// Limpiamos la URL por si trae espacios o caracteres raros de Amazon
const cleanImg = img?.trim();
---

<div class="relative group bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-2xl transition-all duration-300 flex flex-col h-full overflow-hidden">
  
  <!-- ENLACE A TU PÁGINA INTERNA -->
  <a href={`/productos/${id}`} class="flex-grow p-4">
    <!-- Contenedor de Imagen -->
    <div class="w-full h-48 flex items-center justify-center overflow-hidden rounded-lg mb-4 bg-gray-50">
      <img 
        src={cleanImg} 
        alt={title} 
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer" 
        class="max-w-[90%] max-h-[90%] object-contain group-hover:scale-110 transition-transform duration-500"
        onerror="this.src='https://placehold.co';" 
      />
    </div>

    <!-- TÍTULO Y PRECIO -->
    <h2 class="text-lg font-bold text-gray-900 line-clamp-2 h-14 mb-2 group-hover:text-blue-600 transition-colors">
      {title}
    </h2>
    <div class="text-2xl font-black text-blue-600 mb-2">{price}</div>
    
    <!-- ESPECIFICACIONES -->
    <p class="text-sm text-gray-500 italic mb-4 line-clamp-2">
      {specs}
    </p>
  </a>

  <!-- BOTÓN DE AMAZON -->
  <div class="p-4 pt-0">
    <a 
      href={link} 
      target="_blank" 
      rel="nofollow noopener noreferrer" 
      class="relative z-10 bg-[#FF9900] hover:bg-[#F28B00] text-black text-xs font-bold py-3 px-4 rounded-lg transition-all shadow-md flex items-center justify-center gap-2 w-full active:scale-95"
    >
      Ver en Amazon
      <svg xmlns="http://www.w3.org" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
        <path d="M3 6h18"></path>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
    </a>
  </div>
</div>
